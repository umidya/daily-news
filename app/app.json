{
  "expo": {
    "name": "Daily News",
    "slug": "daily-news",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "cover",
      "backgroundColor": "#FFD9C4"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.midya.dailynews",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.midya.dailynews",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FBC0CB"
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "5e916fe2-6099-4cd0-b322-488a40b26e09"
      }
    },
    "owner": "umidya"
  }
}
