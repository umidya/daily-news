# Copy to .env and fill in. Never commit .env.

# Anthropic API key for Claude summarization
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key (used for text-to-speech only)
OPENAI_API_KEY=sk-...

# Public base URL where the digest is hosted (used to build absolute links
# in the podcast RSS feed). Example: https://umidya.github.io/daily-news-a7k2m9q3
DAILY_NEWS_BASE_URL=https://example.github.io/daily-news

# Optional: override the digest date (YYYY-MM-DD). If unset, uses today in PT.
# DAILY_NEWS_DATE=2026-04-27

# Optional: override the runtime mode for local testing.
# - full: fetch + score + summarize + tts + render (default)
# - dry: fetch + score only, no API calls
# DAILY_NEWS_MODE=full
